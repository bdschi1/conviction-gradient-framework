# CGF Configuration
# Rename this file to .env and fill in values

# Database
CGF_DB_PATH=conviction.db

# API
CGF_API_PORT=8000

# Data provider (Yahoo Finance is default, no key needed)
# CGF_DATA_PROVIDER=Yahoo Finance

# Bridge paths (auto-detected if in standard Tier_1 layout)
# CGF_MAIC_PATH=/path/to/multi-agent-investment-committee
# CGF_BACKTEST_LAB_PATH=/path/to/backtest-lab
# CGF_PORTFOLIO_LAB_PATH=/path/to/ls-portfolio-lab
